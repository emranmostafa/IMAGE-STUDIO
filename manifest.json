{
  "manifest_version": 3,
  "name": "Image Variation Studio v3.1",
  "version": "3.1",
  "description": "Bulk image variation with similarity scoring",
  "action": {
    "default_title": "Open Image Studio",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "downloads"]
}